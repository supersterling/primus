{
    "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
    "extends": ["./biome/base.json"],
    "overrides": [
        {
            "includes": ["src/scripts/**"],
            "plugins": [],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noBitwiseOperators": "off",
                        "noNonNullAssertedOptionalChain": "off"
                    },
                    "style": {
                        "noNonNullAssertion": "off"
                    },
                    "complexity": {
                        "noExcessiveCognitiveComplexity": "off"
                    },
                    "nursery": {
                        "useDestructuring": "off"
                    },
                    "performance": {
                        "useTopLevelRegex": "off"
                    }
                }
            }
        },
        {
            "includes": ["src/scripts/style/**", "src/scripts/style/*.ts"],
            "plugins": []
        },
        {
            "includes": ["src/components/icons/**"],
            "linter": { "enabled": false },
            "plugins": []
        },
        {
            "includes": ["src/app/opengraph-image.tsx"],
            "linter": { "enabled": false },
            "plugins": []
        },
        {
            "includes": ["src/components/kibo-ui/**"],
            "linter": { "enabled": false },
            "plugins": []
        }
    ],
    "plugins": [
        "./.grit/error-handling/require-result-trycatch-for-error-handling.grit",
        "./.grit/error-handling/require-explicit-error-cause.grit",
        "./.grit/error-handling/require-logger-call-before-throw.grit",
        "./.grit/error-handling/require-logger-call-before-result-fail.grit",
        "./.grit/error-handling/request-result-fail-over-throw.grit",
        "./.grit/imports/require-absolute-imports-with-at-prefix.grit",
        "./.grit/database/require-explicit-column-selection.grit",
        "./.grit/react/require-named-fragment-over-shorthand.grit",
        "./.grit/react/require-suspense-fallback.grit",
        "./.grit/react/require-suspense-fallback-component.grit",
        "./.grit/react/require-error-boundary-with-suspense.grit",
        "./.grit/style/require-named-function-over-iife.grit",
        "./.grit/style/require-type-guards-over-as-assertion.grit",
        "./.grit/style/require-explicit-nullability-handling.grit",
        "./.grit/react/require-tailwind-over-inline-styles.grit",
        "./.grit/react/require-variable-assignment-for-ternary.grit",
        "./.grit/accessibility/require-aria-label-on-icon-buttons.grit",
        "./.grit/accessibility/require-semantic-button-not-div-onclick.grit",
        "./.grit/accessibility/request-placeholder-with-label.grit",
        "./.grit/accessibility/require-legend-in-fieldset.grit",
        "./.grit/accessibility/request-aria-required-on-required-inputs.grit",
        "./.grit/accessibility/request-autocomplete-on-input-types.grit",
        "./.grit/accessibility/require-paste-enabled-on-inputs.grit",
        "./.grit/accessibility/require-user-scalable-viewport.grit",
        "./.grit/accessibility/require-img-dimensions.grit",
        "./.grit/accessibility/require-video-autoplay-muted.grit",
        "./.grit/react/require-no-forwardRef.grit",
        "./.grit/react/require-use-over-useContext.grit",
        "./.grit/react/require-sync-client-components.grit",
        "./.grit/react/require-metadata-in-server-components.grit",
        "./.grit/react/require-onChange-for-controlled-inputs.grit",
        "./.grit/react/require-next-image-not-html-img.grit",
        "./.grit/react/require-image-sizes-with-fill.grit",
        "./.grit/react/require-direct-child-for-asChild.grit",
        "./.grit/nextjs/require-use-cache-over-unstable-cache.grit",
        "./.grit/nextjs/require-static-apis-in-use-cache.grit",
        "./.grit/nextjs/request-use-server-for-mutations.grit",
        "./.grit/inngest/require-inngest-function-id-literal.grit",
        "./.grit/inngest/require-step-sendEvent-not-inngest-send.grit",
        "./.grit/inngest/request-inngest-event-naming-convention.grit",
        "./.grit/inngest/require-inngest-client-id-slug.grit",
        "./.grit/inngest/require-waitForEvent-timeout.grit",
        "./.grit/inngest/require-singleton-mode-explicit.grit",
        "./.grit/inngest/require-inngest-middleware-correct-import-di.grit",
        "./.grit/inngest/require-inngest-middleware-correct-import-encryption.grit",
        "./.grit/inngest/require-inngest-middleware-correct-import-sentry.grit",
        "./.grit/inngest/require-env-vars-for-inngest-keys.grit",
        "./.grit/inngest/request-inngest-step-id-descriptive.grit",
        "./.grit/inngest/require-batchEvents-timeout-and-maxSize.grit",
        "./.grit/ai-sdk/require-maxOutputTokens-over-maxTokens.grit",
        "./.grit/ai-sdk/require-stopWhen-over-maxSteps.grit",
        "./.grit/ai-sdk/require-inputSchema-over-parameters.grit",
        "./.grit/ai-sdk/require-output-over-generateObject.grit",
        "./.grit/ai-sdk/request-toUIMessageStreamResponse.grit",
        "./.grit/ai-sdk/require-part-input-output-over-args-result.grit",
        "./.grit/ai-sdk/require-addToolOutput-over-addToolResult.grit",
        "./.grit/ai-sdk/require-uiMessages-over-messages.grit",
        "./.grit/library/require-streamdown-caret-with-isAnimating.grit",
        "./.grit/library/require-single-send-for-resend-attachments.grit",
        "./.grit/library/require-single-send-for-resend-scheduled.grit",
        "./.grit/library/require-slack-bolt-ack-in-command.grit",
        "./.grit/library/require-slack-blockkit-fallback-text.grit"
    ]
}
