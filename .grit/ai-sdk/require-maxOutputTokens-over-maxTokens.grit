language js

// Require maxOutputTokens over deprecated maxTokens.

or {
	`generateText({ $props })` as $outer,
	`streamText({ $props })` as $outer
} where {
	$props <: contains `maxTokens: $_` as $match,
	register_diagnostic(
		span=$match,
		message="Use `maxOutputTokens`. `maxTokens` is deprecated in AI SDK 5.",
		severity="error"
	)
}
