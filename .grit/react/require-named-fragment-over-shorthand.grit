language js

// Require named <Fragment> over shorthand <>.

or {
	`<><$children></>` as $match where {
		register_diagnostic(span=$match, message="Use `<Fragment>` from react. `<>` is ambiguous and harder to grep.", severity="error")
	},
	`</>` as $match where {
		register_diagnostic(span=$match, message="Use `<Fragment>` from react. `<>` is ambiguous and harder to grep.", severity="error")
	}
}
