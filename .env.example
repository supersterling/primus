# Auto-generated — run: bun run env:example

# ── Server ──

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/primus"

# Node environment
# development | test | production
NODE_ENV="development"

# Set to '1' to run Inngest in local dev mode (no signing key required)
# 0 | 1
INNGEST_DEV=

# Inngest event key for sending events
INNGEST_EVENT_KEY=

# Inngest signing key for webhook verification
INNGEST_SIGNING_KEY=

# Polar API access token — get this from your sandbox org settings at sandbox.polar.sh
POLAR_ACCESS_TOKEN=

# Polar webhook secret — in dev, copy this from the output of `bun dev:polar`
POLAR_WEBHOOK_SECRET=

# Polar server environment — keep 'sandbox' until you're ready to go live
# sandbox | production
POLAR_SERVER="sandbox"

# Resend API key — get this from resend.com/api-keys
RESEND_API_KEY=
