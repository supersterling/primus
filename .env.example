# Auto-generated — run: bun run env:example

# ── Server ──

# Node environment
# development | test | production
NODE_ENV="development"

# Inngest event key for sending events
INNGEST_EVENT_KEY=

# Inngest signing key for webhook verification
INNGEST_SIGNING_KEY=

# Minimum log level to emit
# DEBUG | INFO | WARN | ERROR
LOGGER_LOWEST_LEVEL="DEBUG"

# Log output format — pretty for dev, json for prod
# pretty | json
LOGGER_FORMAT_STYLE="json"
