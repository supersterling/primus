{
    "name": "primus",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "dev:inngest": "bun --bun inngest-cli dev",
        "dev:polar": "polar listen http://localhost:3000/api/polar/webhook",
        "build": "next build",
        "start": "next start",
        "checks": "bun run ts:check && bun run biome:check && bun run docref:check",
        "docref:check": "docref check",
        "ts:check": "tsc --noEmit",
        "biome:check": "biome check",
        "biome:fix": "biome check --fix",
        "grit:test": "tests/grit/run-tests.sh",
        "db:generate": "bun --bun drizzle-kit generate",
        "db:migrate": "bun --bun drizzle-kit migrate",
        "db:push": "bun --bun drizzle-kit push",
        "db:studio": "bun --bun drizzle-kit studio",
        "env:example": "bun src/scripts/generate-env-example.ts",
        "env:local": "bun src/scripts/generate-env-local.ts",
        "env:pull": "vercel env pull",
        "prepare": "husky"
    },
    "dependencies": {
        "@base-ui/react": "^1.2.0",
        "@clerk/nextjs": "^6.38.2",
        "@hookform/resolvers": "^5.2.2",
        "@inngest/realtime": "^0.4.6",
        "@polar-sh/nextjs": "^0.9.4",
        "@polar-sh/sdk": "^0.46.1",
        "@react-email/components": "^1.0.8",
        "@react-email/render": "^2.0.4",
        "@t3-oss/env-core": "^0.13.10",
        "@t3-oss/env-nextjs": "^0.13.10",
        "@vercel/functions": "^3.4.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "drizzle-orm": "^0.45.1",
        "embla-carousel-react": "^8.6.0",
        "incur": "^0.1.12",
        "inngest": "^4.0.0-beta.2",
        "input-otp": "^1.4.2",
        "lucide-react": "^0.576.0",
        "next": "16.1.6",
        "next-themes": "^0.4.6",
        "pg": "^8.19.0",
        "pino": "^10.3.1",
        "radix-ui": "^1.4.3",
        "react": "19.2.3",
        "react-day-picker": "^9.14.0",
        "react-dom": "19.2.3",
        "react-error-boundary": "^6.1.1",
        "react-hook-form": "^7.71.2",
        "react-resizable-panels": "^4",
        "recharts": "2.15.4",
        "resend": "^6.9.3",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "vaul": "^1.1.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.3.11",
        "@tailwindcss/postcss": "^4",
        "@types/bun": "^1.3.9",
        "@types/node": "^20",
        "@types/pg": "^8.18.0",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "babel-plugin-react-compiler": "^1.0.0",
        "concurrently": "^9.2.1",
        "drizzle-kit": "^0.31.9",
        "husky": "^9.1.7",
        "inngest-cli": "^1.17.1",
        "lint-staged": "^16.2.7",
        "pino-pretty": "^13.1.3",
        "shadcn": "^3.8.5",
        "tailwindcss": "^4",
        "ts-morph": "^27.0.2",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5"
    },
    "ignoreScripts": [
        "sharp",
        "unrs-resolver"
    ],
    "trustedDependencies": [
        "inngest-cli",
        "sharp",
        "unrs-resolver"
    ],
    "lint-staged": {
        "*.{ts,tsx,js,jsx,json,css}": "biome check --write --no-errors-on-unmatched"
    },
    "overrides": {
        "@inngest/realtime": {
            "inngest": "4.0.0-beta.2"
        }
    }
}
